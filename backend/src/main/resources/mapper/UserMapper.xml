<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jin.chat.mapper.UserMapper">

    <select id="selectByUsername" resultType="com.jin.chat.domain.entity.UserDO">
        SELECT *
        FROM users
        WHERE username = #{username}
          AND deleted = FALSE
        LIMIT 1
    </select>

</mapper>
